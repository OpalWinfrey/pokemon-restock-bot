# ── Discord ──────────────────────────────────────────────────────────────────
# Main webhook — all restocks land here unless a hot-product channel is set
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional: separate channel for big hits (ETBs, booster boxes, tins)
DISCORD_HOT_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional: ping this role instead of @everyone (get the role ID from Discord)
DISCORD_ALERT_ROLE_ID=123456789012345678

# Required for slash commands (/status, /setlocation, /subscribe, etc.)
# Get these from discord.com/developers/applications → your app
DISCORD_APP_ID=123456789012345678
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_PUBLIC_KEY=your_public_key_here

# ── Location ─────────────────────────────────────────────────────────────────
# Default zip/radius used as a fallback if a user hasn't run /setlocation
USER_ZIP=90210
SEARCH_RADIUS_MILES=20

# ── Behaviour ─────────────────────────────────────────────────────────────────
# How long before the same product+store can alert again (default: 60 minutes)
ALERT_COOLDOWN_MINUTES=60

# How often to re-search retailers for newly released products (default: 12 hours)
DISCOVER_INTERVAL_HOURS=12

# How often to check inventory (default: 60 seconds)
POLL_INTERVAL_SECONDS=60

# ── Debugging ────────────────────────────────────────────────────────────────
# Set to "debug" to log full API responses (useful when a checker returns wrong results)
LOG_LEVEL=info

# Optional: errors and warnings get posted to this private Discord channel
DISCORD_LOG_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Retailer API Keys ─────────────────────────────────────────────────────────
# Best Buy requires a free API key: https://developer.bestbuy.com
BESTBUY_API_KEY=your_bestbuy_api_key_here
