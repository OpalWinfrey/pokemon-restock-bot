# ── Discord ───────────────────────────────────────────────────────────────────
# Get these from discord.com/developers/applications → your app
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_APP_ID=123456789012345678
DISCORD_PUBLIC_KEY=your_public_key_here

# Your Discord server ID — right-click server name → Copy Server ID
# (Requires Developer Mode: Discord Settings → Advanced → Developer Mode)
DISCORD_GUILD_ID=123456789012345678

# ── Location ──────────────────────────────────────────────────────────────────
# Default location — used until users run /setlocation in Discord
USER_ZIP=60614
SEARCH_RADIUS_MILES=20

# ── Behaviour ─────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=60
DISCOVER_INTERVAL_HOURS=12
ALERT_COOLDOWN_MINUTES=60

# ── Debugging ─────────────────────────────────────────────────────────────────
# "info" for normal use, "debug" to see full API responses when troubleshooting
LOG_LEVEL=info

